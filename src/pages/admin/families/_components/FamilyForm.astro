---
import Input from '@/components/shared/Input.astro';
import type { Family } from '@/types/family';

interface Props {
  family?: Family;
}

const { family } = Astro.props;
const mode = family ? 'edit' : 'create';
---

<form data-family-form data-mode={mode}>
  {family && <input type="hidden" name="id" value={family.id} />}
  <Input
    name="name"
    label="Nombre"
    required
    placeholder="Ingrese el nombre de la familia"
    value={family?.name}
  />
  <button class="btn btn-primary mt-4">Guardar</button>
</form>

<script>
  import { actions } from 'astro:actions';

  const form = document.querySelector<HTMLFormElement>('form[data-family-form]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const action = form.dataset.mode === 'edit' ? actions.updateFamily : actions.createFamily;
    const { error } = await action(fd);
    if (error) {
      alert(error.message);
      return;
    }
    window.location.href = '/admin/families';
  });
</script>
