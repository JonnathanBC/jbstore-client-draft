---
import Input from '@/components/shared/Input.astro';
import Password from '@/icons/Password.astro';
import User from '@/icons/User.astro';
import Deliveries from '@/icons/Deliveries.astro';
import Google from '@/icons/Google.astro';
---

<div class="flex min-h-screen">
  <!-- Register form -->
  <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
    <form id="auth-form" method="POST" class="w-full max-w-sm space-y-4">
      <h2 class="text-2xl font-bold text-slate-900">Crear Cuenta</h2>
      <Input label="Name" name="name" icon={User} required />
      <Input label="Email" name="email" type="email" icon={User} required />
      <Input label="Password" name="password" type="password" icon={Password} required />
      <Input
        label="Confirm Password"
        name="confirm_password"
        type="password"
        icon={Password}
        required
      />

      <div class="mt-12">
        <button
          id="btn-submit"
          type="submit"
          class="w-full shadow-xl py-2.5 px-4 text-[15px] font-medium tracking-wide rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
        >
          Crear cuenta
        </button>

        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-slate-200"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="bg-white px-4 text-slate-500">or continua con</span>
          </div>
        </div>

        <a
          href="/api/auth/google"
          class="w-full flex items-center justify-center gap-3 py-2.5 px-4 border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors"
        >
          <Google class="w-5 h-5" />
          <span class="text-sm font-medium text-slate-700">Login con Google</span>
        </a>

        <p class="text-sm mt-6! text-center text-slate-600">
          Ya tiene una cuenta? <a
            href="/login"
            class="text-blue-600 font-medium hover:underline ml-1">Sign in</a
          >
        </p>
      </div>
    </form>
  </div>

  <!-- Illustration (hidden on mobile) -->
  <div class="hidden lg:flex w-1/2 items-center justify-center bg-slate-50">
    <Deliveries class="w-4/5 max-w-lg" />
  </div>
</div>

<script>
  import { actions } from 'astro:actions';
  import { sileo } from 'sileo';

  const form = document.querySelector('form') as HTMLFormElement;
  const btnSubmit = document.querySelector('#btn-submit') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnSubmit.setAttribute('disabled', 'disabled');

    const formData = new FormData(form);
    const { error } = await actions.registerUser(formData);

    if (error) {
      sileo.error({
        title: 'Credenciales no son correctas',
        description: error.message,
      });
      btnSubmit.removeAttribute('disabled');
      return;
    }

    window.location.replace('/');
  });
</script>
