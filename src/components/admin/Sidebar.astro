---
import Dashboard from '@/icons/Dashboard.astro';
import Navbar from './Navbar.astro';
import { cn } from '@/lib/utils';

const pathname = Astro.url.pathname;

const menuItems = [
  {
    key: 'dashboard',
    label: 'Dashboard',
    href: '/admin',
    icon: Dashboard,
  },
  {
    key: 'families',
    label: 'Familias',
    href: '/admin/families',
    icon: Dashboard,
  },
];
---

<Navbar />

<aside
  id="top-bar-sidebar"
  class="fixed top-0 left-0 z-40 w-64 h-dvh pt-20 transition-transform -translate-x-full bg-white border-r border-gray-100 sm:translate-x-0"
  aria-label="Sidebar"
>
  <div class="h-full px-3 pb-4 overflow-y-auto bg-white flex flex-col">
    <ul class="space-y-2 flex-1">
      {
        menuItems.map((menu) => {
          const isActive =
            menu.href === '/admin' ? pathname === '/admin' : pathname.startsWith(menu.href);

          return (
            <li>
              <a
                href={menu.href}
                class={cn(
                  'flex items-center p-2 hover:text-purple-600 rounded-lg hover:bg-purple-100 group',
                  {
                    'text-purple-600 bg-purple-100': isActive,
                  },
                )}
              >
                <menu.icon className="group-hover:text-purple-600" />
                <span class="ms-3">{menu.label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <button
      id="logout-btn"
      type="button"
      class="flex items-center p-2 mt-4 text-red-600 rounded-lg hover:bg-red-50 cursor-pointer border-t border-gray-100 pt-4"
    >
      <span class="ms-3">Cerrar sesión</span>
    </button>
  </div>
</aside>

<div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/40 hidden sm:hidden"></div>

<script>
  import { actions } from 'astro:actions';
  import { isSidebarOpen } from '@/stores';

  const sidebar = document.getElementById('top-bar-sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const logoutBtn = document.getElementById('logout-btn');

  logoutBtn?.addEventListener('click', async () => {
    await actions.logoutAction({});
    window.location.href = '/login';
  });

  // Cerrar sidebar
  const closeSidebar = () => isSidebarOpen.set(false);

  overlay?.addEventListener('click', closeSidebar);

  isSidebarOpen.subscribe((open) => {
    // Sidebar
    sidebar?.classList.toggle('-translate-x-full', !open);
    sidebar?.classList.toggle('translate-x-0', open);
    sidebar?.classList.toggle('ease-out', open);
    sidebar?.classList.toggle('ease-in', !open);

    // Overlay
    overlay?.classList.toggle('hidden', !open);
  });
</script>
